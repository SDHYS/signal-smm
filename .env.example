# 로컬 개발용 환경변수 견본.  복사:  cp .env.example .env

# 로컬 DB (infra/docker-compose.local.yml 의 Postgres, 호스트 포트 5433)
DATABASE_URL="postgresql://signalsmm:signalsmm_local_pw@localhost:5433/signalsmm?schema=public"

# 세션 서명 키 (32바이트 이상).  운영에서는 반드시 무작위 값으로 교체.
AUTH_SECRET="dev_secret_change_me_at_least_32_bytes_long_000"

# (선택) 시드 관리자 계정 오버라이드
# SEED_ADMIN_EMAIL=admin@signalsmm.local
# SEED_ADMIN_PASSWORD=Admin1234!
