# 운영 docker compose 용 환경변수 견본.
# 복사:  cp infra/.env.example infra/.env  후 값 채우기 (infra/.env 는 git 에 올리지 않음)

# PostgreSQL
POSTGRES_USER=signalsmm
POSTGRES_PASSWORD=__강력한_비밀번호로_교체__
POSTGRES_DB=signalsmm

# 앱 → DB 연결 (compose 네트워크 내부 호스트명 db)
DATABASE_URL=postgresql://signalsmm:__강력한_비밀번호로_교체__@db:5432/signalsmm?schema=public

# 세션 서명 키 (32바이트 이상 무작위 문자열).  openssl rand -base64 48
AUTH_SECRET=__32바이트_이상_무작위_문자열__
