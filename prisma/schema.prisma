// SignalSMM - 소셜미디어 마케팅 쇼핑몰 DB 스키마
// 결제: 무통장입금/계좌이체(수동 입금확인). PG 연동 없음.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── 회원 ─────────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique // 로그인 아이디
  email         String   @unique // 계정 분실 시 확인용
  passwordHash  String
  name          String
  phone         String?
  signupChannel String? // 가입 경로(구글/네이버/지인 등)
  balance       Int      @default(0) // 보유잔액(원)
  role          Role     @default(USER)
  orders        Order[]
  charges       ChargeRequest[]
  inquiries     Inquiry[]
  notifications Notification[]
  favorites     Favorite[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

// ── 잔액충전 신청(무통장입금 수동확인) ──────────────
enum ChargeStatus {
  PENDING // 입금 대기
  CONFIRMED // 입금 확인됨(잔액 반영 완료)
  CANCELLED // 취소
}

model ChargeRequest {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  amount        Int // 충전 금액(원) — 확인 시 balance 에 가산
  vat           Int          @default(0) // 부가세
  total         Int // 입금해야 할 총액(amount + vat)
  depositorName String // 입금자명
  receiptType   String       @default("신청안함") // 신청안함/세금계산서/현금영수증
  receiptDetail String?      @db.Text // 영수증 상세(JSON: 회사정보 또는 휴대폰번호)
  status        ChargeStatus @default(PENDING)
  confirmedById String? // 입금확인 처리한 관리자
  confirmedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@map("charge_requests")
}

// ── 상품(SMM 서비스: 인스타 팔로워, 유튜브 조회수 등) ──
model Product {
  id          String      @id @default(cuid())
  category    String // 플랫폼/카테고리: 인스타그램, 유튜브, 틱톡 ...
  name        String // 예: 인스타그램 한국인 팔로워
  description String?     @db.Text
  unitPrice   Int // 1개당 가격(원, 정수)
  minQty      Int         @default(1)
  maxQty      Int         @default(100000)
  isActive    Boolean     @default(true)
  // 도매(공급사) 연동 — 매핑되면 주문 시 자동 발주
  providerServiceId Int? // 공급사 서비스 ID
  providerRate      Float? // 매핑 시점 도매 단가 스냅샷 (USD/1000)
  providerMeta      String? @db.Text // 공급사 서비스명·min/max 등 스냅샷(JSON)
  sortOrder   Int         @default(0)
  orderItems  OrderItem[]
  favorites   Favorite[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("products")
}

// ── 주문 ─────────────────────────────────────────────
enum OrderStatus {
  PENDING_PAYMENT // 입금 대기
  PAID // 입금 확인됨(관리자가 결제완료 처리)
  PROCESSING // 작업 진행중
  COMPLETED // 작업 완료
  CANCELLED // 취소
}

model Order {
  id            String      @id @default(cuid())
  orderNo       String      @unique // 사람이 읽는 주문번호 (예: 20260629-0001)
  clientKey     String?     @unique // 클라이언트 생성 멱등성 키 (중복 제출 방지)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        OrderStatus @default(PENDING_PAYMENT)
  totalAmount   Int // 총 결제금액(원)
  depositorName String? // 입금자명
  memo          String?     @db.Text // 고객 메모
  adminMemo     String?     @db.Text // 관리자 메모
  items         OrderItem[]
  paidAt        DateTime? // 입금확인(결제완료) 시각
  confirmedById String? // 입금확인 처리한 관리자 id
  completedAt   DateTime? // 작업완료 시각
  cancelledAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String // 주문 시점 상품명 스냅샷
  unitPrice   Int // 주문 시점 단가 스냅샷
  quantity    Int
  subtotal    Int // unitPrice * quantity
  targetUrl   String? // 작업 대상 링크(게시물/계정 URL)
  // 도매(공급사) 발주 상태
  providerServiceIdSnapshot Int? // 주문 시점 매핑된 도매 서비스 ID (이후 재매핑돼도 이 값으로 발주)
  providerOrderId String? // 공급사 주문번호
  providerStatus  String? // Pending | In progress | Completed | Partial | Canceled ...
  providerRemains Int? // 미완료 잔여 수량 (Partial 시 환불 계산용)
  providerError   String? @db.Text // 발주 실패 사유 (재발주 대상 표시)
  sentAt          DateTime? // 발주 시각
  syncedAt        DateTime? // 마지막 상태 동기화 시각

  @@index([orderId])
  @@index([providerOrderId])
  @@map("order_items")
}

// ── 사이트 설정(입금계좌 등 key-value) ───────────────
model Setting {
  key       String   @id // 예: bank_name, bank_account, bank_holder, site_name
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── 공지사항 ─────────────────────────────────────────
model Notice {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  authorName String   @default("관리자")
  views      Int      @default(0)
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
  @@map("notices")
}

// ── 블로그 ───────────────────────────────────────────
model BlogPost {
  id           String   @id @default(cuid())
  category     String   @default("업데이트") // 인스타그램/네이버/유튜브/틱톡/업데이트
  title        String
  content      String   @db.Text
  authorName   String   @default("관리자")
  thumbnailUrl String?
  tags         String[] @default([])
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
  @@map("blog_posts")
}

// ── 1:1 문의 ─────────────────────────────────────────
enum InquiryStatus {
  PENDING // 답변대기
  ANSWERED // 답변완료
}

model Inquiry {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  title        String
  content      String        @db.Text
  status       InquiryStatus @default(PENDING)
  answer       String?       @db.Text
  answeredById String?
  answeredAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@map("inquiries")
}

// ── 알림 (주문/충전/문의/관리자 쪽지) ────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("system") // order | charge | inquiry | message
  title     String
  body      String?  @db.Text
  link      String? // 클릭 시 이동 경로
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ── 관리자 감사 로그(돈 관련 조치 추적) ─────────────
// 환불·잔액조정·충전확인·비번초기화 등 민감 조치의 실행자·사유·금액을 불변 기록.
// adminId=null 은 시스템 자동 처리(크론 동기화 자동환불 등).
model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String? // 실행 관리자 id (시스템 자동이면 null)
  adminName   String   @default("시스템") // 실행자 표시명 스냅샷
  action      String // charge.confirm | charge.cancel | order.refund | order.status | balance.adjust | password.reset | sync.refund
  targetType  String // charge | order | user
  targetId    String
  targetLabel String? // 사람이 읽는 대상 라벨(주문번호/회원명 등)
  reason      String?  @db.Text // 조치 사유
  amount      Int? // 금액 변화(환불액/조정액/적립액)
  meta        String?  @db.Text // 추가 상세(JSON)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("admin_audit_logs")
}

// ── 즐겨찾기(회원별 상품) ─────────────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@map("favorites")
}
